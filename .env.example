# Local development: a SQLite file. (Default if DATABASE_URL is unset.)
DATABASE_URL="file:./dev.db"

# Production (Turso): use the libsql:// URL and an auth token instead.
# DATABASE_URL="libsql://<your-db>-<org>.turso.io"
# TURSO_AUTH_TOKEN="<token from `turso db tokens create`>"

# Password protection (Basic Auth). If APP_PASSWORD is set, the whole app
# requires login. APP_USER defaults to "admin". Leave APP_PASSWORD unset
# locally to keep dev open.
# APP_USER="admin"
# APP_PASSWORD="choose-a-strong-password"
