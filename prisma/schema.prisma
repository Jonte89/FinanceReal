// Prisma schema for the Personal Finance & Wealth Tracker
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  transactions        Transaction[]
  stockHoldings       StockHolding[]
  savingsAccount      SavingsAccount?
  savingsTransactions SavingsTransaction[]
  setting             AppSetting?
}

model Transaction {
  id          String   @id @default(cuid())
  date        DateTime
  type        String // "INCOME" or "EXPENSE"
  amount      Float // Value in SEK
  category    String // Rent, Food, Subscriptions, Salary, Dividends, etc.
  description String?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StockHolding {
  id        String   @id @default(cuid())
  ticker    String // e.g., "INVE-B.ST" (SEK) or "AAPL" (USD)
  shares    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One interest-bearing account per user.
model SavingsAccount {
  id                 String   @id @default(cuid())
  name               String   @default("Nordiska Flex Plus")
  principalBalance   Float // The actual deposited/capitalized balance
  accruedInterest    Float    @default(0) // Unpaid interest waiting to be capitalized
  lastCalculatedDate DateTime // Used to calculate daily interest gap
  updatedAt          DateTime @updatedAt
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// One row of preferences per user.
model AppSetting {
  id        String   @id @default(cuid())
  cutoffDay Int      @default(25) // Day of month a new budget period starts (1-28)
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsTransaction {
  id        String   @id @default(cuid())
  date      DateTime
  type      String // "DEPOSIT" or "WITHDRAWAL"
  amount    Float // Value in SEK
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
