// Prisma schema for the Personal Finance & Wealth Tracker
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Transaction {
  id          String   @id @default(cuid())
  date        DateTime
  type        String // "INCOME" or "EXPENSE"
  amount      Float // Value in SEK
  category    String // Rent, Food, Subscriptions, Salary, Dividends, etc.
  description String?
  createdAt   DateTime @default(now())
}

model StockHolding {
  id        String   @id @default(cuid())
  ticker    String // e.g., "INVE-B.ST" (SEK) or "AAPL" (USD)
  shares    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavingsAccount {
  id                 String   @id @default(cuid())
  name               String   @default("Nordiska Flex Plus")
  principalBalance   Float // The actual deposited/capitalized balance
  accruedInterest    Float    @default(0) // Unpaid interest waiting to be capitalized
  lastCalculatedDate DateTime // Used to calculate daily interest gap
  updatedAt          DateTime @updatedAt
}

model SavingsTransaction {
  id        String   @id @default(cuid())
  date      DateTime
  type      String // "DEPOSIT" or "WITHDRAWAL"
  amount    Float // Value in SEK
  createdAt DateTime @default(now())
}
